{
  "name": "image-optimizer-action",
  "version": "1.3.0",
  "private": true,
  "description": "A GitHub Action to optimize images",
  "license": "GPL-3.0",
  "author": "Chad Adams",
  "main": "./dist/index.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "build": "npm run type-check && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:sharp",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "tsx src/test.ts",
    "changeset": "changeset"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "glob": "^11.0.3",
    "sharp": "^0.34.3",
    "svgo": "^3.3.2",
    "table": "^6.9.0"
  },
  "devDependencies": {
    "@lazy-release/changesets": "^0.7.0",
    "@types/node": "^22.16.3",
    "esbuild": "^0.25.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
